// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth User model with backend compatibility
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  // Additional fields for backend compatibility
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  password_hash String?   @db.VarChar(255)

  // Default font preferences
  default_font_family String?   @default("TikTokSans-Regular") @db.VarChar(100)
  default_font_size   Int?      @default(24)
  default_font_color  String?   @default("#FFFFFF") @db.VarChar(7)

  is_admin             Boolean   @default(false)

  // Relationships
  tasks         Task[]
  sessions      Session[]
  accounts      Account[]
  app_settings   AppSetting[]   @relation("UserAppSettings")
  owner_settings OwnerSetting[] @relation("UserOwnerSettings")
  model_profiles ModelProfile[] @relation("UserModelProfiles")
  prompt_versions PromptVersion[] @relation("UserPromptVersions")
  workflows      Workflow[]     @relation("UserWorkflows")

  @@map("users")
}

model AppSetting {
  setting_key     String   @id @db.VarChar(100)
  encrypted_value String
  prefer_admin_value Boolean @default(false)
  updated_by      String?  @db.VarChar(36)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  user            User?    @relation("UserAppSettings", fields: [updated_by], references: [id], onDelete: SetNull)

  @@index([updated_by])
  @@map("app_settings")
}

model OwnerSetting {
  setting_key String   @id @db.VarChar(100)
  value_json  String
  updated_by  String?  @db.VarChar(36)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  user        User?    @relation("UserOwnerSettings", fields: [updated_by], references: [id], onDelete: SetNull)

  @@index([updated_by])
  @@map("owner_settings")
}

model ModelProfile {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(100)
  provider      String   @db.VarChar(40)
  model         String   @db.VarChar(160)
  purpose       String   @db.VarChar(80)
  is_default    Boolean  @default(false)
  settings_json String   @default("{}")
  updated_by    String?  @db.VarChar(36)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  user          User?    @relation("UserModelProfiles", fields: [updated_by], references: [id], onDelete: SetNull)

  @@index([purpose])
  @@index([is_default])
  @@index([updated_by])
  @@map("model_profiles")
}

model PromptVersion {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(120)
  purpose       String   @db.VarChar(80)
  version       Int      @default(1)
  prompt_text   String
  metadata_json String   @default("{}")
  is_active     Boolean  @default(true)
  updated_by    String?  @db.VarChar(36)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  user          User?    @relation("UserPromptVersions", fields: [updated_by], references: [id], onDelete: SetNull)

  @@unique([name, version])
  @@index([purpose])
  @@index([is_active])
  @@index([updated_by])
  @@map("prompt_versions")
}

model Workflow {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(120)
  description   String?
  source_type   String   @default("youtube") @db.VarChar(40)
  output_target String   @default("shorts") @db.VarChar(40)
  config_json   String   @default("{}")
  is_default    Boolean  @default(false)
  updated_by    String?  @db.VarChar(36)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  user          User?    @relation("UserWorkflows", fields: [updated_by], references: [id], onDelete: SetNull)

  @@index([source_type])
  @@index([output_target])
  @@index([is_default])
  @@index([updated_by])
  @@map("workflows")
}

model Task {
  id                   String    @id @default(uuid())
  user_id              String
  source_id            String?
  generated_clips_ids  String[]
  status               String    @default("pending") @db.VarChar(20)
  progress             Int?      @default(0)
  progress_message     String?
  error_code           String?   @db.VarChar(80)
  error_message        String?
  current_stage        String?   @db.VarChar(40)
  failed_stage         String?   @db.VarChar(40)
  resume_from_stage    String?   @db.VarChar(40)
  stage_progress_json  String?
  retry_count          Int       @default(0)
  max_retries          Int       @default(3)
  last_error_at        DateTime? @db.Timestamptz

  // Font customization fields
  font_family          String?   @default("TikTokSans-Regular") @db.VarChar(100)
  font_size            Int?      @default(24)
  font_color           String?   @default("#FFFFFF") @db.VarChar(7)
  caption_template     String?   @default("default") @db.VarChar(50)
  include_broll        Boolean?  @default(false)

  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz

  // Relationships
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  source               Source?   @relation(fields: [source_id], references: [id], onDelete: SetNull)
  artifacts            TaskArtifact[]
  library_metadata     TaskLibraryMetadata?
  generated_clips      GeneratedClip[]
  publish_metadata     ClipPublishMetadata[]

  @@index([user_id])
  @@index([source_id])
  @@index([created_at])
  @@index([status])
  @@index([current_stage])
  @@index([failed_stage])
  @@map("tasks")
}

model TaskLibraryMetadata {
  task_id        String   @id
  tags           String[] @default([])
  content_pillar String?  @db.VarChar(120)
  series_name    String?  @db.VarChar(160)
  platform       String?  @db.VarChar(40)
  library_status String   @default("draft") @db.VarChar(40)
  pinned         Boolean  @default(false)
  archived       Boolean  @default(false)
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz

  task           Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([content_pillar])
  @@index([series_name])
  @@index([platform])
  @@index([library_status])
  @@index([pinned])
  @@index([archived])
  @@map("task_library_metadata")
}

model TaskArtifact {
  id             String    @id @default(uuid())
  task_id        String
  artifact_type  String    @db.VarChar(60)
  text_value     String?
  json_value     Json?
  file_path      String?
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz

  task           Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([task_id, artifact_type])
  @@index([task_id])
  @@index([artifact_type])
  @@index([file_path])
  @@map("task_artifacts")
}

model Source {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(20)
  title      String   @db.VarChar(500)
  url        String?  @db.VarChar(1000)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  // Relationships
  tasks      Task[]

  @@index([created_at])
  @@map("sources")
}

model GeneratedClip {
  id                 String   @id @default(uuid())
  task_id            String   @db.VarChar(36)
  filename           String   @db.VarChar(255)
  file_path          String   @db.VarChar(500)
  start_time         String   @db.VarChar(20)
  end_time           String   @db.VarChar(20)
  duration           Float
  text               String?
  relevance_score    Float
  reasoning          String?
  clip_order         Int
  virality_score     Int?     @default(0)
  hook_score         Int?     @default(0)
  engagement_score   Int?     @default(0)
  value_score        Int?     @default(0)
  shareability_score Int?     @default(0)
  hook_type          String?  @db.VarChar(50)
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz

  task               Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  publish_metadata   ClipPublishMetadata[]

  @@index([task_id])
  @@map("generated_clips")
}

model ClipPublishMetadata {
  id             String    @id @default(uuid())
  clip_id        String    @db.VarChar(36)
  task_id        String    @db.VarChar(36)
  platform       String    @db.VarChar(40)
  post_status    String    @default("draft") @db.VarChar(40)
  caption        String?
  hashtags       String[]  @default([])
  checklist_json Json      @default("{}")
  published_url  String?
  published_at   DateTime? @db.Timestamptz
  export_path    String?
  notes          String?
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz

  clip           GeneratedClip @relation(fields: [clip_id], references: [id], onDelete: Cascade)
  task           Task          @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([clip_id, platform])
  @@index([clip_id])
  @@index([task_id])
  @@index([platform])
  @@index([post_status])
  @@index([published_at])
  @@map("clip_publish_metadata")
}

// Better Auth Session management
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
