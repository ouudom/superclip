# Required: transcription
ASSEMBLY_AI_API_KEY=
ASSEMBLY_AI_HTTP_TIMEOUT_SECONDS=900

# Required: choose one transcript-analysis LLM
LLM=9router:your-model

# 9router local/OpenAI-compatible endpoint
# Local backend default: http://localhost:4000/v1
# Docker default: http://host.docker.internal:4000/v1
NINEROUTER_BASE_URL=
NINEROUTER_API_KEY=

# Hosted LLM alternatives
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Ollama alternative
# LLM=ollama:gpt-oss:20b
OLLAMA_BASE_URL=
OLLAMA_API_KEY=

# Optional source/download providers
YOUTUBE_DOWNLOAD_PROVIDER=yt_dlp
YOUTUBE_METADATA_PROVIDER=yt_dlp
YOUTUBE_DATA_API_KEY=
APIFY_API_TOKEN=
APIFY_YOUTUBE_DEFAULT_QUALITY=1080
APIFY_RUN_TIMEOUT_SECONDS=900
PEXELS_API_KEY=

# App/auth
SELF_HOST=true
BETTER_AUTH_SECRET=supoclip_dev_secret_change_in_production
BACKEND_AUTH_SECRET=change_me_backend_auth_secret
APP_SETTINGS_ENCRYPTION_KEY=change_me_settings_encryption_secret
ALLOW_PUBLIC_SIGNUP=false
DISABLE_SIGN_UP=false
ALLOW_UNSIGNED_BACKEND_AUTH=false
AUTH_SIGNATURE_TTL_SECONDS=300

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3107
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LANDING_ONLY_MODE=false
BETTER_AUTH_TRUSTED_ORIGINS=
CORS_ORIGINS=http://localhost:3107,http://sp.localhost:3107,http://supoclip.localhost:3107

# Processing
DEFAULT_PROCESSING_MODE=fast
FAST_MODE_MAX_CLIPS=4
FAST_MODE_TRANSCRIPT_MODEL=universal
QUEUED_TASK_TIMEOUT_SECONDS=180
WORKER_MAX_JOBS=1

# Database pool
BACKEND_DATABASE_POOL_SIZE=20
BACKEND_DATABASE_MAX_OVERFLOW=20
WORKER_DATABASE_POOL_SIZE=5
WORKER_DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=10

# Storage/cleanup
TEMP_CLEANUP_ENABLED=true
TEMP_CLEANUP_MAX_AGE_HOURS=168
WATCHED_SOURCE_DIR=watched
HOST_WATCHED_SOURCE_DIR=./watched
PUBLISH_EXPORT_DIR=exports
HOST_PUBLISH_EXPORT_DIR=./exports

# Docker services
POSTGRES_DB=supoclip
POSTGRES_USER=supoclip
POSTGRES_PASSWORD=supoclip_password
REDIS_PASSWORD=
